# Semeron — 環境変数テンプレート
# ローカルは supabase start の出力値、本番は hosted Supabase / Vercel の値を設定。
# SUPABASE_SERVICE_ROLE_KEY / VAPID_PRIVATE_KEY / ANTHROPIC_API_KEY / CRON_SECRET は
# サーバー専用。絶対にクライアントへ露出しないこと。

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3070

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- 通知: Web Push (VAPID) ---
# 生成: node -e "const w=require('web-push');console.log(w.generateVAPIDKeys())"
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# --- 通知: メール (Resend, 任意) ---
RESEND_API_KEY=
NOTIFICATIONS_FROM_EMAIL=Semeron <noreply@example.com>

# --- 通知ディスパッチ cron の保護 ---
CRON_SECRET=

# --- Pastor Assist (管理者限定AI, サーバー専用) ---
# 未設定なら Pastor Assist は自動的に無効（UIは案内表示のみ）。
ANTHROPIC_API_KEY=
PASTOR_ASSIST_MODEL=claude-sonnet-5
