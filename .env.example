# Aster Daily — 環境変数テンプレート
# Phase 1（デモUI）では、これらは不要です。デモは決定論的なローカルデータで動きます。
# Phase 2 以降（Supabase / 通知 / Pastor Assist）で使用します。
# SUPABASE_SERVICE_ROLE_KEY と OPENAI_API_KEY は絶対にクライアントへ露出しないこと。

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3070

# --- Supabase (Phase 2+) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Email (Phase 4+) ---
RESEND_API_KEY=

# --- Pastor Assist / AI (Phase 5+, server-side only) ---
OPENAI_API_KEY=

# --- Web Push (Phase 4+) ---
WEB_PUSH_PUBLIC_KEY=
WEB_PUSH_PRIVATE_KEY=
WEB_PUSH_SUBJECT=
