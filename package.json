{
  "name": "semeron",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3070",
    "build": "next build",
    "start": "next start -p 3070",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npm run db:start && npm run db:reset && playwright test",
    "test:e2e:no-reset": "playwright test",
    "test:e2e:headed": "npm run db:start && npm run db:reset && playwright test --headed",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:test": "supabase test db",
    "db:test:reset": "npm run db:reset && npm run db:test",
    "db:types": "supabase gen types typescript --db-url \"postgresql://postgres:postgres@127.0.0.1:54622/postgres\" --schema public > app/lib/database.types.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.68.0",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "2.110.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.469.0",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "server-only": "^0.0.1",
    "tailwind-merge": "^2.6.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "@vitejs/plugin-react": "5.2.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "jsdom": "^25.0.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite": "8.1.3",
    "vitest": "4.1.9"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.10"
    }
  },
  "packageManager": "npm@11.17.0"
}
